MAILMIND_CONFIG_PATH=config/mailmind.yaml
MAILMIND_DB_PATH=data/mailmind.db
MAILMIND_LOG_PATH=data/logs/audit.jsonl
MAILMIND_POLICY_PATH=agents/mailmind/policies/default_policy.yaml
MAILMIND_SOURCE=fake
MAILMIND_GMAIL_SEED_PATH=data/seed/demo_messages.json
MAILMIND_TOOL_CATALOG_PATH=data/tool_catalog.json
MAILMIND_CLASSIFIER_MODE=rules
MAILMIND_LLM_ENABLED=false
MAILMIND_LLM_PROVIDER=huggingface
MAILMIND_LLM_MODEL_NAME=Qwen/Qwen3-1.7B
MAILMIND_LLM_DEVICE_MAP=auto
MAILMIND_LLM_TORCH_DTYPE=auto
MAILMIND_LLM_MAX_NEW_TOKENS=384
MAILMIND_LLM_THINKING=true
MAILMIND_PLANNER_LLM_ENABLED=false
MAILMIND_PLANNER_PROVIDER=function_gemma
MAILMIND_PLANNER_MODEL_NAME=google/functiongemma-270m-it
MAILMIND_PLANNER_DEVICE_MAP=auto
MAILMIND_PLANNER_TORCH_DTYPE=auto
MAILMIND_PLANNER_MAX_NEW_TOKENS=128
MAILMIND_WHATSAPP_MODE=fake
MAILMIND_WHATSAPP_ALLOWLIST=+911234567890
MAILMIND_NOTIFICATION_DESTINATION=+911234567890
MAILMIND_VIEWER_HOST=127.0.0.1
MAILMIND_VIEWER_PORT=8000
MAILMIND_POLL_SECONDS=300

# TODO: Real Gmail OAuth credentials/settings.
MAILMIND_GMAIL_CLIENT_ID=
MAILMIND_GMAIL_CLIENT_SECRET=

# TODO: Real Twilio WhatsApp credentials/settings.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
